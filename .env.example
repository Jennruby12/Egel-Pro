# ============================================================
# EGELPro — Variables de entorno
# Copiar este archivo como .env.local y rellenar los valores
# NUNCA commitear .env.local al repositorio
# ============================================================

# --- SUPABASE ---
# Obtener en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- EMAIL (Resend) ---
# Obtener en: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- SUPABASE MCP (para Claude Code) ---
# Obtener Access Token en: supabase.com → Account → Access Tokens
# Obtener Project Ref en: tu proyecto → Settings → General → Reference ID
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxx

# --- IA TUTOR (agregar cuando llegues a V2) ---
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# --- PAGOS (agregar cuando llegues a V3) ---
